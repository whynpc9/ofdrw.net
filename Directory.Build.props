<Project>
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>

    <RepositoryUrl>https://github.com/whynpc9/ofdrw.net</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/whynpc9/ofdrw.net</PackageProjectUrl>
    <Authors>whynpc9</Authors>
    <Company>whynpc9</Company>
    <Copyright>Copyright (c) whynpc9</Copyright>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Keep shipping XML documentation while allowing public API docs to be
         completed incrementally. Other XML documentation diagnostics, such as
         malformed cref/param tags, remain enabled. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <VersionPrefix Condition="'$(VersionPrefix)' == ''">0.1.0</VersionPrefix>
    <VersionSuffix Condition="'$(VersionSuffix)' == ''">preview.4</VersionSuffix>
    <PackageVersion Condition="'$(PackageVersion)' == ''">$(VersionPrefix)-$(VersionSuffix)</PackageVersion>
    <Version Condition="'$(Version)' == ''">$(PackageVersion)</Version>
  </PropertyGroup>

  <ItemGroup Condition="'$(IsPackable)' != 'false'">
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="/" Link="README.md" />
    <None Include="$(MSBuildThisFileDirectory)THIRD-PARTY-NOTICES.md" Pack="true" PackagePath="/" Link="THIRD-PARTY-NOTICES.md" />
    <None Include="$(MSBuildThisFileDirectory)docs/feature-parity.md" Pack="true" PackagePath="docs/" Link="docs/feature-parity.md" />
  </ItemGroup>
</Project>
